# ─── Database ───────────────────────────────────────────
# Neon pooled connection string used by the application runtime.
DATABASE_URL="postgresql://user:password@project-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Neon direct connection string used by Prisma migrations and admin tooling.
DIRECT_URL="postgresql://user:password@project.region.aws.neon.tech/neondb?sslmode=require"

# ─── JWT Secrets ────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET="your-access-secret-here"
JWT_REFRESH_SECRET="your-refresh-secret-here"

# ─── AI Provider ────────────────────────────────────────
# Switch between "anthropic" and "openai".
# At least one provider key must be configured for AI routes.
AI_PROVIDER="anthropic"
AI_TIMEOUT_MS="45000"
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."

# ─── Google Drive Sync ───────────────────────────────────
# Source spreadsheet/file ID from the Drive URL: /d/{FILE_ID}/
GOOGLE_DRIVE_FILE_ID="your-file-id-here"

# The importer accepts large operational workbooks up to 100,000 total rows.

# Optional. Service account JSON encoded as base64.
# If absent, the source file must be public: Anyone with the link → Viewer.
# Generate with: base64 -i service-account.json
GOOGLE_SERVICE_ACCOUNT_KEY="base64-encoded-json"

# Optional. Folder ID for server-side Google Sheets exports.
# The folder must be shared with the service account email.
GOOGLE_DRIVE_EXPORT_FOLDER_ID="your-export-folder-id-here"

# ─── App ────────────────────────────────────────────────
# Public app URL used by emails, redirects, and integrations.
NEXT_PUBLIC_APP_URL="https://your-production-domain.example"

# Hosting platforms usually set NODE_ENV for production builds.
NODE_ENV="production"
